.productos-page {
  background: #f7f3ea;
}

.detalles-page {
  background: #f4f4f1;
}

.page-shell {
  max-width: 1180px;
  margin: 0 auto;
}

.soft-shadow {
  box-shadow: 0 12px 28px rgba(17, 24, 39, 0.08);
}

.detalles-wrap {
  max-width: 1140px;
  margin: 0 auto;
  padding: 22px 18px;
}

.detalles-breadcrumb {
  margin: 0 0 12px;
  font-size: 13px;
  color: #6b7280;
}

.detalles-breadcrumb a {
  color: #4b5563;
  text-decoration: none;
}

.detalles-breadcrumb a:hover {
  color: #c5096f;
}

.detalles-nav-actions {
  display: none;
  gap: 14px;
}

.detalles-nav-link {
  color: #fff;
  font-size: 14px;
  text-decoration: none;
  opacity: 0.92;
}

.detalles-nav-link:hover {
  opacity: 1;
}

.detalles-card {
  border: 1px solid #ddddda;
  background: #f2f1ed;
  border-radius: 12px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 48% 52%;
  box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
}

.detalles-image-col {
  min-height: 620px;
  position: relative;
  background: #f4f5f6;
}

.detalles-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.detalles-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 13px;
  background: #caeec3;
  color: #325f2d;
}

.detalles-content-col {
  padding: 24px 30px;
}

.detalles-kicker {
  font-size: 13px;
  color: #6b7280;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.detalles-title {
  font-size: 52px;
  line-height: 1;
  letter-spacing: -0.4px;
  color: #1f2321;
}

.detalles-tags {
  margin-top: 10px;
  font-size: 12px;
  letter-spacing: 1.6px;
  color: #5f8f59;
}

.detalles-meta {
  margin-top: 10px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.detalles-meta span {
  font-size: 12px;
  color: #5b6473;
  background: #e9e9e4;
  padding: 6px 10px;
  border-radius: 999px;
}

.detalles-price-box {
  margin-top: 18px;
  border-radius: 10px;
  background: #f6f5f2;
  padding: 16px;
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.detalles-price {
  font-size: 40px;
  font-weight: 800;
  color: #c5096f;
}

.detalles-unit {
  font-size: 16px;
  color: #4b5563;
}

.detalles-subtitle {
  margin-top: 20px;
  margin-bottom: 12px;
  font-size: 30px;
  color: #1f2321;
}

.detalles-benefits {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.detalles-benefits li {
  font-size: 19px;
  color: #334155;
}

.detalles-actions {
  margin-top: 20px;
  display: grid;
  grid-template-columns: 1fr 190px;
  gap: 12px;
}

.detalles-btn {
  border: 0;
  border-radius: 10px;
  padding: 14px 18px;
  font-size: 21px;
  font-weight: 700;
  cursor: pointer;
}

.detalles-btn-primary {
  background: #d00972;
  color: #fff;
}

.detalles-btn-secondary {
  background: #e3e3e0;
  color: #d00972;
}

.detalles-description {
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid #d8d8d6;
  font-size: 18px;
  line-height: 1.5;
  color: #4b5563;
}

.detalles-note {
  margin-top: 14px;
  border-left: 3px solid #d6d3d1;
  padding-left: 10px;
}

.detalles-note p {
  margin: 0;
  font-size: 14px;
  color: #6b7280;
}

.detalles-back-link {
  display: inline-block;
  margin-top: 14px;
  color: #c5096f;
  font-weight: 600;
}

@media (max-width: 980px) {
  .detalles-card {
    grid-template-columns: 1fr;
  }

  .detalles-image-col {
    min-height: 360px;
  }

  .detalles-title {
    font-size: 40px;
  }

  .detalles-subtitle {
    font-size: 26px;
  }

  .detalles-price {
    font-size: 34px;
  }

  .detalles-benefits li {
    font-size: 17px;
  }

  .detalles-btn {
    font-size: 18px;
  }

  .detalles-description {
    font-size: 16px;
  }

  .detalles-breadcrumb {
    margin-bottom: 10px;
  }
}

@media (max-width: 700px) {
  .detalles-nav-actions {
    display: flex;
  }

  .detalles-content-col {
    padding: 18px;
  }

  .detalles-title {
    font-size: 32px;
  }

  .detalles-subtitle {
    font-size: 24px;
  }

  .detalles-actions {
    grid-template-columns: 1fr;
  }

  .detalles-benefits {
    grid-template-columns: 1fr;
  }
}
